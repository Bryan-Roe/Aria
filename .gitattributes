# Normalize line endings to LF on commit
* text=auto eol=lf

# Force LF for these file types regardless of platform
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.css text eol=lf

# Binary files - never convert
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.zip binary
*.gz binary
*.tar binary
*.npz binary
*.npy binary
*.pt binary
*.safetensors binary
