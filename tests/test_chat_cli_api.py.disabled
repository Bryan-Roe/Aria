"""Tests for talk-to-ai chat CLI and API"""
import pytest
from unittest.mock import Mock, patch, MagicMock
import json
from io import StringIO


class TestChatCLI:
    """Test chat CLI functionality"""
    
    def test_chat_cli_help(self):
        """Test chat CLI help message"""
        help_text = "usage: chat_cli.py [--provider PROVIDER]"
        assert "--provider" in help_text
    
    def test_parse_cli_arguments(self):
        """Test parsing CLI arguments"""
        args = [
            "--provider", "openai",
            "--model", "gpt-3.5-turbo",
            "--once", "Hello"
        ]
        
        # Should parse successfully
        assert "--provider" in args
        assert "openai" in args
    
    @patch("talk_to_ai.src.chat_cli.get_chat_client")
    def test_send_single_message(self, mock_get_client):
        """Test sending a single message"""
        mock_client = Mock()
        mock_client.chat.completions.create.return_value = Mock(
            choices=[Mock(message=Mock(content="Response"))]
        )
        mock_get_client.return_value = mock_client
        
        message = "Hello"
        # Should send and get response
        assert message is not None
    
    @patch("talk_to_ai.src.chat_cli.get_chat_client")
    def test_stream_response(self, mock_get_client):
        """Test streaming response"""
        mock_client = Mock()
        mock_stream = [
            Mock(choices=[Mock(delta=Mock(content="Hello"))]),
            Mock(choices=[Mock(delta=Mock(content=" "))]),
            Mock(choices=[Mock(delta=Mock(content="world"))]),
        ]
        mock_client.chat.completions.create.return_value = iter(mock_stream)
        mock_get_client.return_value = mock_client
        
        # Should stream response chunks
        assert mock_client is not None
    
    def test_provider_selection(self):
        """Test provider selection from CLI"""
        providers = ["azure_openai", "openai", "lmstudio", "local"]
        
        for provider in providers:
            assert provider in providers
    
    def test_model_selection(self):
        """Test model selection"""
        models = {
            "openai": ["gpt-4", "gpt-3.5-turbo"],
            "azure_openai": ["gpt-4", "gpt-35-turbo"],
            "lmstudio": ["neural-chat"],
            "local": ["echo"]
        }
        
        for provider, model_list in models.items():
            assert len(model_list) > 0
    
    def test_system_prompt_config(self):
        """Test system prompt configuration"""
        system_prompt = "You are a helpful assistant."
        
        assert len(system_prompt) > 0
        assert "helpful" in system_prompt
    
    def test_temperature_setting(self):
        """Test temperature parameter"""
        temperatures = [0.0, 0.5, 0.7, 1.0]
        
        for temp in temperatures:
            assert 0.0 <= temp <= 1.0


class TestChatAPI:
    """Test chat API endpoints"""
    
    def test_chat_endpoint_exists(self):
        """Test /api/chat endpoint exists"""
        endpoint = "/api/chat"
        assert "chat" in endpoint
    
    @patch("function_app.get_chat_client")
    def test_send_chat_message(self, mock_get_client):
        """Test sending chat message via API"""
        mock_client = Mock()
        mock_client.chat.completions.create.return_value = Mock(
            choices=[Mock(message=Mock(content="Response"))]
        )
        mock_get_client.return_value = mock_client
        
        request_body = {
            "messages": [
                {"role": "user", "content": "Hello"}
            ],
            "provider": "local"
        }
        
        assert "messages" in request_body
    
    def test_streaming_chat_response(self):
        """Test streaming chat response via SSE"""
        response_format = "data: {json_data}\n\n"
        
        assert "data:" in response_format
    
    def test_chat_with_context(self):
        """Test chat with conversation context"""
        context = [
            {"role": "user", "content": "Hello"},
            {"role": "assistant", "content": "Hi there!"},
            {"role": "user", "content": "How are you?"}
        ]
        
        assert len(context) == 3
        assert context[0]["role"] == "user"
    
    def test_error_handling(self):
        """Test error handling in chat API"""
        error_response = {
            "error": "Provider not available",
            "provider": "invalid_provider"
        }
        
        assert "error" in error_response
    
    def test_timeout_handling(self):
        """Test timeout handling"""
        timeout_seconds = 30
        
        assert timeout_seconds > 0
    
    def test_max_tokens_limit(self):
        """Test max tokens parameter"""
        max_tokens = 2048
        
        assert max_tokens > 0


class TestChatFormatting:
    """Test chat message formatting"""
    
    def test_format_user_message(self):
        """Test formatting user message"""
        message = {
            "role": "user",
            "content": "Hello"
        }
        
        assert message["role"] == "user"
        assert len(message["content"]) > 0
    
    def test_format_assistant_message(self):
        """Test formatting assistant message"""
        message = {
            "role": "assistant",
            "content": "Hi there!"
        }
        
        assert message["role"] == "assistant"
    
    def test_format_system_message(self):
        """Test formatting system message"""
        message = {
            "role": "system",
            "content": "You are helpful"
        }
        
        assert message["role"] == "system"
    
    def test_message_validation(self):
        """Test message validation"""
        valid_roles = ["user", "assistant", "system"]
        test_role = "user"
        
        assert test_role in valid_roles
    
    def test_escape_special_characters(self):
        """Test escaping special characters in messages"""
        message = 'User said: "Hello \\n world"'
        
        assert "\\" in message or "n" in message


class TestChatSessionManagement:
    """Test chat session management"""
    
    def test_session_creation(self):
        """Test creating a chat session"""
        session_id = "test_session_123"
        
        assert len(session_id) > 0
    
    def test_session_persistence(self):
        """Test persisting session data"""
        session_data = {
            "session_id": "test_session",
            "messages": [],
            "created_at": "2024-01-17T10:00:00Z"
        }
        
        assert "session_id" in session_data
    
    def test_session_expiry(self):
        """Test session expiry"""
        ttl_seconds = 3600  # 1 hour
        
        assert ttl_seconds > 0
    
    def test_session_cleanup(self):
        """Test cleaning up expired sessions"""
        expired_sessions = []
        
        # Should remove expired sessions
        assert isinstance(expired_sessions, list)


