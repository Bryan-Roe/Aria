{
  "configurations": [
    {
      "type": "debugpy",
      "request": "launch",
      "name": "Python: MCP Script",
      "program": "${workspaceFolder}/AI/microsoft_phi-silica-3.6_v1/python mcp.py",
      "console": "integratedTerminal",
      "env": {
        "GITHUB_TOKEN": "${input:githubToken}",
        "MEMORY_FILE_PATH": "${input:memoryFilePath}"
      }
    },
    {
      "type": "debugpy",
      "request": "launch",
      "name": "Python: Quantum Classifier",
      "program": "${workspaceFolder}/AI/quantum-ai/src/quantum_classifier.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "type": "debugpy",
      "request": "launch",
      "name": "Python: Hybrid QNN",
      "program": "${workspaceFolder}/AI/quantum-ai/src/hybrid_qnn.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "type": "debugpy",
      "request": "launch",
      "name": "Python: Azure Quantum Integration",
      "program": "${workspaceFolder}/AI/quantum-ai/src/azure_quantum_integration.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "type": "debugpy",
      "request": "launch",
      "name": "Python: Chat CLI",
      "program": "${workspaceFolder}/talk-to-ai/src/chat_cli.py",
      "console": "integratedTerminal",
      "args": []
    },
    {
      "type": "debugpy",
      "request": "launch",
      "name": "Python: Chat CLI (One-shot)",
      "program": "${workspaceFolder}/talk-to-ai/src/chat_cli.py",
      "console": "integratedTerminal",
      "args": [
        "--once",
        "${input:chatMessage}"
      ]
    }
  ],
  "inputs": [
    {
      "type": "promptString",
      "id": "githubToken",
      "description": "Enter your GitHub Personal Access Token"
    },
    {
      "type": "promptString",
      "id": "memoryFilePath",
      "description": "Enter the memory file path"
    },
    {
      "type": "promptString",
      "id": "chatMessage",
      "description": "Enter your chat message"
    }
  ]
}