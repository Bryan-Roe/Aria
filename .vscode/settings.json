        "-v",
        "--tb=short",
        "--no-header",
        "--color=yes"
    ],
    "python.testing.cwd": "${workspaceFolder}",
    "python.testing.autoTestDiscoverOnSaveEnabled": true,
    "powershell.scriptAnalysis.settingsPath": "quantum/.vscode/PSScriptAnalyzerSettings.psd1",
