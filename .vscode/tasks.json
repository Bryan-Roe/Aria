{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "func: host start",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"if command -v func >/dev/null 2>&1; then func host start; else echo \"[func: host start] Azure Functions Core Tools (func) not found on PATH; skipping local host startup.\"; echo \"Job host started (skipped: func missing)\"; fi"
			],
			"isBackground": true,
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": {
				"pattern": [
					{
						"regexp": "^.*$",
						"file": 0,
						"location": 1,
						"message": 2
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "Worker process started and initialized|Host lock lease acquired|Job host started|Http Functions:|Job host started (skipped: func missing)"
				}
			}
		},
		{
			"label": "integration:contract-gate",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"bash ./scripts/integration_contract_gate.sh"
			],
			"dependsOn": [
				"func: host start"
			],
			"problemMatcher": []
		},
		{
			"label": "integration:contract-gate-direct",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"bash ./scripts/integration_contract_gate.sh"
			],
			"problemMatcher": []
		},
		{
			"label": "integration:contract-gate-strict",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"bash ./scripts/integration_contract_gate.sh --strict-endpoints"
			],
			"dependsOn": [
				"func: host start"
			],
			"problemMatcher": []
		},
		{
			"label": "integration:contract-gate-strict-direct",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"bash ./scripts/integration_contract_gate.sh --strict-endpoints"
			],
			"problemMatcher": []
		},
		{
			"label": "integration:contract-gate-strict-direct-autostart",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"if command -v func >/dev/null 2>&1; then START_FUNC_CMD=\"func host start\" bash ./scripts/integration_contract_gate.sh --strict-endpoints; else echo \"[integration:contract-gate-strict-direct-autostart] func not found on PATH; run integration:contract-gate-direct instead.\"; exit 0; fi"
			],
			"problemMatcher": []
		},
		{
			"label": "validate:site-bundles-strict",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"python3 scripts/validate_site_bundles.py --strict-metadata"
			],
			"problemMatcher": []
		},
		{
			"label": "smoke: quantum-ai-code-llm",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"python3 quantum-ai/scripts/smoke_quantum_code_llm.py --backend classical --epochs 1"
			],
			"problemMatcher": []
		},
		{
			"label": "validate: foundry-config",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"python3 scripts/validate_foundry_config.py"
			],
			"problemMatcher": []
		},
		{
			"label": "automate: core-files",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"python3 scripts/automate_core_files.py --json"
			],
			"problemMatcher": []
		},
		{
			"label": "automation: go-forever",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"cd \"${workspaceFolder}\" && mkdir -p data_out && nohup bash ./scripts/aria_forever_watchdog.sh >> data_out/aria_forever_watchdog.log 2>&1 & echo 'started: scripts/aria_forever_watchdog.sh'"
			],
			"problemMatcher": []
		},
		{
			"label": "automation: go-forever-status",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"cd \"${workspaceFolder}\" && if [ -f data_out/aria_forever_watchdog_heartbeat.json ]; then cat data_out/aria_forever_watchdog_heartbeat.json; else echo '{\"running\":false,\"reason\":\"heartbeat file missing\"}'; fi"
			],
			"problemMatcher": []
		},
		{
			"label": "Run Gradio AI Chat app",
			"type": "shell",
			"command": "${command:python.interpreterPath}",
			"args": [
				"scripts/gradio_hello.py"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "smoke: ai/routes",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"curl -fsS http://127.0.0.1:7071/api/ai/routes | python3 -m json.tool"
			],
			"dependsOn": [
				"func: host start"
			],
			"problemMatcher": []
		},
		{
			"label": "smoke: ai/provider-probe",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"curl -fsS -X POST http://127.0.0.1:7071/api/ai/provider-probe -H 'Content-Type: application/json' -d '{\"provider\":\"auto\"}' | python3 -m json.tool"
			],
			"dependsOn": [
				"func: host start"
			],
			"problemMatcher": []
		},
		{
			"label": "smoke: ai/agi/status",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"curl -fsS http://127.0.0.1:7071/api/agi/status | python3 -m json.tool"
			],
			"dependsOn": [
				"func: host start"
			],
			"problemMatcher": []
		},
		{
			"label": "smoke: ai/agi/analyze",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"curl -fsS -X POST http://127.0.0.1:7071/api/agi/analyze -H 'Content-Type: application/json' -d '{\"query\":\"reason through this architecture\"}' | python3 -m json.tool"
			],
			"dependsOn": [
				"func: host start"
			],
			"problemMatcher": []
		},
		{
			"label": "smoke: ai/agi/stream",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"curl -fsS -N -X POST http://127.0.0.1:7071/api/agi/stream -H 'Content-Type: application/json' -d '{\"query\":\"stream a short response\"}' | grep -q 'data: DONE' && echo '{\"status\":\"ok\",\"done\":true}' | python3 -m json.tool"
			],
			"dependsOn": [
				"func: host start"
			],
			"problemMatcher": []
		},
		{
			"label": "Validate writer-reviewer debug prerequisites",
			"type": "aitk",
			"command": "debug-check-prerequisites",
			"args": {
				"portOccupancy": [
					5679,
					8088
				]
			}
		},
		{
			"label": "Run writer-reviewer HTTP server",
			"type": "shell",
			"command": "${command:python.interpreterPath} -m debugpy --listen 127.0.0.1:5679 -m agentdev run ai-projects/writer-reviewer-workflow/main.py --verbose --port 8088",
			"isBackground": true,
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"dependsOn": [
				"Validate writer-reviewer debug prerequisites"
			],
			"problemMatcher": {
				"pattern": [
					{
						"regexp": "^.*$",
						"file": 0,
						"location": 1,
						"message": 2
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "Application startup complete|running on|Started server process"
				}
			}
		},
		{
			"label": "Open writer-reviewer Agent Inspector",
			"type": "shell",
			"command": "echo '${input:openWriterReviewerInspector}'",
			"presentation": {
				"reveal": "never"
			},
			"dependsOn": [
				"Run writer-reviewer HTTP server"
			]
		},
		{
			"label": "Terminate All Tasks",
			"type": "shell",
			"command": "echo ${input:terminate}",
			"problemMatcher": []
		}
	],
	"inputs": [
		{
			"id": "openWriterReviewerInspector",
			"type": "command",
			"command": "ai-mlstudio.openTestTool",
			"args": {
				"triggeredFrom": "tasks",
				"port": 8088
			}
		},
		{
			"id": "terminate",
			"type": "command",
			"command": "workbench.action.tasks.terminate",
			"args": "terminateAll"
		}
	]
}