{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pip install (functions)",
      "type": "shell",
      "command": "if [ -f ./venv/bin/python ]; then ./venv/bin/python -m pip install -r requirements.txt; else python3 -m pip install -r requirements.txt; fi",
      "windows": {
        "command": "if (Test-Path '.\\venv\\Scripts\\python.exe') { .\\venv\\Scripts\\python.exe -m pip install -r requirements.txt } else { python -m pip install -r requirements.txt }"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$python"],
      "group": "build"
    },
    {
      "label": "pip install (talk-to-ai)",
      "type": "shell",
      "command": "if [ -f ./venv/bin/python ]; then ./venv/bin/python -m pip install -r requirements.txt; else python3 -m pip install -r requirements.txt; fi",
      "windows": {
        "command": "if (Test-Path '.\\venv\\Scripts\\python.exe') { .\\venv\\Scripts\\python.exe -m pip install -r requirements.txt } else { python -m pip install -r requirements.txt }"
      },
      "options": {
        "cwd": "${workspaceFolder}/talk-to-ai"
      },
      "problemMatcher": []
    },
    {
      "label": "pip install (quantum-ai)",
      "type": "shell",
      "command": "if [ -f ./venv/bin/python ]; then ./venv/bin/python -m pip install -r requirements.txt; else python3 -m pip install -r requirements.txt; fi",
      "windows": {
        "command": "if (Test-Path '.\\venv\\Scripts\\python.exe') { .\\venv\\Scripts\\python.exe -m pip install -r requirements.txt } else { python -m pip install -r requirements.txt }"
      },
      "options": {
        "cwd": "${workspaceFolder}/quantum-ai"
      },
      "problemMatcher": []
    },
    {
      "type": "func",
      "label": "func: host start",
      "command": "host start",
      "problemMatcher": "$func-python-watch",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "pip install (functions)",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run: Local LoRA training",
      "type": "shell",
      "command": "python",
      "args": ["scripts/training/run_local_lora_training.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: AutoTrain (dry-run)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/training/autotrain.py", "--dry-run"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: AutoTrain (all)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/training/autotrain.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: LoRA quick (streaming)",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/train_lora.py",
        "--dataset",
        "../../datasets/chat/mixed_chat",
        "--max-train-samples",
        "64",
        "--max-eval-samples",
        "16",
        "--epochs",
        "1"
      ],
      "options": {
        "cwd": "${workspaceFolder}/AI/microsoft_phi-silica-3.6_v1"
      }
    },
    {
      "label": "Run: LoRA quick (non-stream)",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/train_lora.py",
        "--dataset",
        "../../datasets/chat/mixed_chat",
        "--max-train-samples",
        "64",
        "--max-eval-samples",
        "16",
        "--epochs",
        "1",
        "--no-stream"
      ],
      "options": {
        "cwd": "${workspaceFolder}/AI/microsoft_phi-silica-3.6_v1"
      }
    },
    {
      "label": "Run: Quantum AutoRun (dry-run)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/evaluation/quantum_autorun.py", "--dry-run"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Quantum AutoRun (all)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/evaluation/quantum_autorun.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Evaluation AutoRun (dry-run)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/evaluation/evaluation_autorun.py", "--dry-run"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Evaluation AutoRun (all)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/evaluation/evaluation_autorun.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: CI Validate All",
      "type": "shell",
      "command": "python",
      "args": ["scripts/orchestrators/ci_orchestrator.py", "--validate-all"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: CI Pipeline",
      "type": "shell",
      "command": "python",
      "args": ["scripts/orchestrators/ci_orchestrator.py", "--ci-pipeline"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Master Orchestrator - Quick Validation",
      "type": "shell",
      "command": "python",
      "args": ["scripts/orchestrators/master_orchestrator.py", "--workflow", "quick_validation"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Master Orchestrator - Status",
      "type": "shell",
      "command": "python",
      "args": ["scripts/orchestrators/master_orchestrator.py", "--status"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Model Deployer - Scan",
      "type": "shell",
      "command": "python",
      "args": ["scripts/evaluation/model_deployer.py", "--scan"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Model Deployer - Deploy Best",
      "type": "shell",
      "command": "python",
      "args": ["scripts/evaluation/model_deployer.py", "--deploy", "best", "--strategy", "canary"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Resource Monitor - Snapshot",
      "type": "shell",
      "command": "python",
      "args": ["scripts/monitoring/resource_monitor.py", "--snapshot"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Resource Monitor - Stream",
      "type": "shell",
      "command": "python",
      "args": ["scripts/monitoring/resource_monitor.py", "--stream", "--duration", "60"],
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Batch Evaluator - Scan",
      "type": "shell",
      "command": "python",
      "args": ["scripts/evaluation/batch_evaluator.py", "--scan-models", "--evaluate-all"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Results Exporter - Export to Markdown",
      "type": "shell",
      "command": "python",
      "args": ["scripts/evaluation/results_exporter.py", "--all", "--format", "markdown"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Auto Scheduler - List",
      "type": "shell",
      "command": "python",
      "args": ["scripts/orchestrators/auto_scheduler.py", "--list"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Tests - All Fast",
      "type": "shell",
      "command": "python",
      "args": ["scripts/test_runner.py", "--all"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Tests - Unit Only",
      "type": "shell",
      "command": "python",
      "args": ["scripts/test_runner.py", "--unit"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Tests - Integration",
      "type": "shell",
      "command": "python",
      "args": ["scripts/test_runner.py", "--integration"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Tests - With Coverage",
      "type": "shell",
      "command": "python",
      "args": ["scripts/test_runner.py", "--all", "--coverage"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run: Tests - Watch Mode",
      "type": "shell",
      "command": "python",
      "args": ["scripts/test_runner.py", "--unit", "--integration", "--watch"],
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Automate: Train & Promote (Quick)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/training/train_and_promote.py", "--quick", "--auto-promote"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Automate: Train & Promote (Standard)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/training/train_and_promote.py", "--standard", "--auto-promote"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Automate: Grid Search",
      "type": "shell",
      "command": "python",
      "args": ["scripts/training/training_scheduler.py", "--grid-search"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Automate: Start Nightly Training",
      "type": "shell",
      "command": "python",
      "args": ["scripts/training/training_scheduler.py", "--start", "nightly"],
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Automate: Full Pipeline (Train + Eval + Deploy)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/training/train_and_promote.py", "--full", "--auto-promote", "--max-workers", "2"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Train: Aria Movement (Quick)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/training/autotrain.py", "--config", "autotrain_aria.yaml", "--job", "aria_movement_quick"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Visualize: GGUF File (CLI)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/visualize_gguf_simple.py", "${input:ggufFile}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Visualize: GGUF Quantum Banknote Model",
      "type": "shell",
      "command": "python",
      "args": ["scripts/visualize_gguf_simple.py", "data_out/quantum_banknote_perfect_model.gguf"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Visualize: Export GGUF Analysis (JSON + MD)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/visualize_gguf_simple.py", "${input:ggufFile}", "--json", "data_out/gguf_analysis.json", "--md", "data_out/gguf_analysis.md"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Visualize: Start GGUF Web Server",
      "type": "shell",
      "command": "python",
      "args": ["serve_gguf_viz.py"],
      "options": {
        "cwd": "${workspaceFolder}/dashboard"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "GGUF: Quick Training",
      "type": "shell",
      "command": "python",
      "args": ["scripts/training/gguf_training_automation.py", "--quick"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "GGUF: Full Pipeline",
      "type": "shell",
      "command": "python",
      "args": ["scripts/training/gguf_training_automation.py", "--full"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "GGUF: Dry-Run",
      "type": "shell",
      "command": "python",
      "args": ["scripts/training/gguf_training_automation.py", "--quick", "--dry-run"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "GGUF: Convert Existing Model",
      "type": "shell",
      "command": "python",
      "args": ["scripts/training/gguf_training_automation.py", "--convert-only", "${input:loraModelPath}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "GGUF: Validate Model",
      "type": "shell",
      "command": "python",
      "args": ["scripts/training/gguf_training_automation.py", "--validate", "${input:ggufFile}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Monitor: Auto Ops Dashboard",
      "type": "shell",
      "command": "python",
      "args": ["scripts/monitoring/auto_ops_dashboard.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Monitor: Auto Ops (Watch)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/monitoring/auto_ops_dashboard.py", "--watch"],
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Monitor: Auto Ops (Problems Only)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/monitoring/auto_ops_dashboard.py", "--problems"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Monitor: Auto Ops (Compact)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/monitoring/auto_ops_dashboard.py", "--compact"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Monitor: Auto Ops (Export JSON)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/monitoring/auto_ops_dashboard.py", "--export"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Monitor: Auto Ops Quick Ref",
      "type": "shell",
      "command": "python",
      "args": ["scripts/monitoring/auto_ops_quick_ref.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Monitor: Dashboard Server (VS Code)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/monitoring/vs_code_server.py"],
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Server starting.*",
          "endsPattern": "^.*Ctrl\\+C to stop.*"
        }
      }
    },
    {
      "label": "Monitor: Alert Monitor (Background)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/monitoring/vs_code_alert_monitor.py"],
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Monitor: Start Full VS Code Suite",
      "dependsOn": [
        "Monitor: Dashboard Server (VS Code)",
        "Monitor: Alert Monitor (Background)"
      ],
      "dependsOrder": "parallel",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "Monitor: Quick Setup (Interactive Menu)",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/monitoring/vscode_quickstart.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "new"
      }
    }
  ],
  "inputs": [
    {
      "id": "ggufFile",
      "type": "promptString",
      "description": "Path to GGUF file",
      "default": "data_out/quantum_banknote_perfect_model.gguf"
    },
    {
      "id": "loraModelPath",
      "type": "promptString",
      "description": "Path to LoRA model directory",
      "default": "data_out/lora_training/phi35/checkpoint-100"
    }
  ]
}
