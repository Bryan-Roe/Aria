{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "func",
			"label": "func: host start",
			"command": "host start",
			"problemMatcher": "$func-python-watch",
			"isBackground": true,
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"dependsOn": "pip install (functions)",
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "pip install (functions)",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"windows": {
				"command": "if (Test-Path '.\\venv\\Scripts\\python.exe') { .\\venv\\Scripts\\python.exe -m pip install -r requirements.txt } else { python -m pip install -r requirements.txt }",
				"options": {
					"shell": {
						"executable": "powershell.exe",
						"args": [
							"-Command"
						]
					}
				}
			},
			"osx": {
				"command": "if [ -f ./venv/bin/python ]; then ./venv/bin/python -m pip install -r requirements.txt; else python3 -m pip install -r requirements.txt; fi"
			},
			"linux": {
				"command": "if [ -f ./venv/bin/python ]; then ./venv/bin/python -m pip install -r requirements.txt; else python3 -m pip install -r requirements.txt; fi"
			},
			"problemMatcher": []
		},
		{
			"label": "Run: Local LoRA training",
			"type": "shell",
			"command": "python",
			"args": [
				".\\scripts\\run_local_lora_training.py"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Run: AutoTrain (dry-run)",
			"type": "shell",
			"options": { "cwd": "${workspaceFolder}" },
			"command": "python",
			"args": [
				".\\scripts\\autotrain.py",
				"--dry-run"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Run: AutoTrain (all)",
			"type": "shell",
			"options": { "cwd": "${workspaceFolder}" },
			"command": "python",
			"args": [
				".\\scripts\\autotrain.py"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Run: LoRA quick (streaming)",
			"type": "shell",
			"options": { "cwd": "${workspaceFolder}\\AI\\microsoft_phi-silica-3.6_v1" },
			"command": ".\\venv\\Scripts\\python.exe",
			"args": [
				".\\scripts\\train_lora.py",
				"--dataset", "..\\..\\datasets\\chat\\mixed_chat",
				"--max-train-samples", "64",
				"--max-eval-samples", "16",
				"--epochs", "1"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Run: LoRA quick (non-stream)",
			"type": "shell",
			"options": { "cwd": "${workspaceFolder}\\AI\\microsoft_phi-silica-3.6_v1" },
			"command": ".\\venv\\Scripts\\python.exe",
			"args": [
				".\\scripts\\train_lora.py",
				"--dataset", "..\\..\\datasets\\chat\\mixed_chat",
				"--max-train-samples", "64",
				"--max-eval-samples", "16",
				"--epochs", "1",
				"--no-stream"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Run: Quantum AutoRun (dry-run)",
			"type": "shell",
			"options": { "cwd": "${workspaceFolder}" },
			"command": "python",
			"args": [
				".\\scripts\\quantum_autorun.py",
				"--dry-run"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Run: Quantum AutoRun (all)",
			"type": "shell",
			"options": { "cwd": "${workspaceFolder}" },
			"command": "python",
			"args": [
				".\\scripts\\quantum_autorun.py"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "pip install (quantum-ai)",
			"type": "shell",
			"windows": {
				"command": ".\\quantum-ai\\venv\\Scripts\\python.exe -m pip install -r .\\quantum-ai\\requirements.txt"
			},
			"osx": {
				"command": "./quantum-ai/venv/bin/python -m pip install -r ./quantum-ai/requirements.txt"
			},
			"linux": {
				"command": "./quantum-ai/venv/bin/python -m pip install -r ./quantum-ai/requirements.txt"
			},
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "pip install (talk-to-ai)",
			"type": "shell",
			"windows": {
				"command": ".\\talk-to-ai\\venv\\Scripts\\python.exe -m pip install -r .\\talk-to-ai\\requirements.txt"
			},
			"osx": {
				"command": "./talk-to-ai/venv/bin/python -m pip install -r ./talk-to-ai/requirements.txt"
			},
			"linux": {
				"command": "./talk-to-ai/venv/bin/python -m pip install -r ./talk-to-ai/requirements.txt"
			},
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "pip install (functions)",
			"type": "shell",
			"command": "if (Test-Path '.\\venv\\Scripts\\python.exe') { .\\venv\\Scripts\\python.exe -m pip install -r requirements.txt } else { python -m pip install -r requirements.txt }",
			"problemMatcher": [
				"$python"
			],
			"group": "build"
		},
		{
			"label": "pip install (functions)",
			"type": "shell",
			"command": "if (Test-Path '.\\venv\\Scripts\\python.exe') { .\\venv\\Scripts\\python.exe -m pip install -r requirements.txt } else { python -m pip install -r requirements.txt }",
			"group": "build"
		}
	]
}