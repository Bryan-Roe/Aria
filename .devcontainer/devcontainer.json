// Aria development container (root workspace)
{
  "name": "Aria Dev Container",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-windows-ai-studio.windows-ai-studio"
      ]
    }
  },

  "postCreateCommand": "python -m venv .venv ; . .venv/bin/activate ; python -m pip install --upgrade pip ; if [ -f requirements.txt ]; then pip install -r requirements.txt; else echo 'No root requirements.txt found; skipping dependency install.'; fi",

  "postStartCommand": "python --version && pip --version",

  "remoteEnv": {
    "PYTHONUNBUFFERED": "1"
  }
}
