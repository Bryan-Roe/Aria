<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build">
  <Sdk Name="Microsoft.Build.Sql" Version="1.0.0" />
  <PropertyGroup>
    <Name>database</Name>
    <ProjectGuid>{2B66B28B-4B76-4EC0-9233-243AD1C19215}</ProjectGuid>
    <DSP>Microsoft.Data.Tools.Schema.Sql.SqlAzureV12DatabaseSchemaProvider</DSP>
    <ModelCollation>1033, CI</ModelCollation>
  </PropertyGroup>
  <ItemGroup>
    <!-- Configuration -->
    <None Include=".vscode\tasks.json" />
    <None Include="README.md" />
    
    <!-- Tables -->
    <Build Include="Tables\QuantumTrainingRuns.sql" />
    <Build Include="Tables\LoRATrainingRuns.sql" />
    <Build Include="Tables\ChatConversations.sql" />
    <Build Include="Tables\Datasets.sql" />
    <Build Include="Tables\AzureQuantumJobs.sql" />
    <Build Include="Tables\OrchestratorJobs.sql" />
    <Build Include="Tables\MCPServerSessions.sql" />
    
    <!-- Views -->
    <Build Include="Views\vw_TrainingRunsSummary.sql" />
    <Build Include="Views\vw_DatasetUsageStats.sql" />
    <Build Include="Views\vw_AzureQuantumCostTracking.sql" />
    
    <!-- Stored Procedures -->
    <Build Include="StoredProcedures\sp_LogQuantumTrainingRun.sql" />
    <Build Include="StoredProcedures\sp_LogLoRATrainingRun.sql" />
    <Build Include="StoredProcedures\sp_LogChatConversation.sql" />
    <Build Include="StoredProcedures\sp_RegisterDataset.sql" />
  </ItemGroup>
  <Target Name="BeforeBuild">
    <Delete Files="$(BaseIntermediateOutputPath)\project.assets.json" />
  </Target>
</Project>