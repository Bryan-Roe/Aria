# Writer-Reviewer Workflow — Environment Configuration
# -------------------------------------------------------
# Copy this file to .env and fill in the values below.
# The .env file is automatically loaded by main.py at startup.

# ── Microsoft Foundry ─────────────────────────────────────────────────────
# Your Foundry project endpoint (found in AI Toolkit → Foundry panel, or
# in the Azure Portal → AI Foundry resource → Project overview).
AZURE_AI_PROJECT_ENDPOINT=https://AI-1424-resource.services.ai.azure.com/api/projects/AI-1424

# The name of a deployed chat model in your Foundry project.
# Recommended default for this workflow in AI-1424: gpt-oss-120b.
# If your Foundry project uses a different deployment name, replace it here.
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-oss-120b
